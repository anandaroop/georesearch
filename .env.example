# keys
GEORESEARCH_ANTHROPIC_API_KEY=sk-REPLACE
GEORESEARCH_OPENAI_API_KEY=REPLACE

# model
GEORESEARCH_DEFAULT_MODEL=claude-sonnet-4-6
# GEORESEARCH_DEFAULT_MODEL=gpt-5.4

# concurrency
GEORESEARCH_MAX_WORKERS=4

# MCP server URL
GEORESEARCH_MCP_SERVER_URL=http://localhost:3000/mcp

# uncomment to see verbose LLM I/O logged to terminal
# RUBYLLM_DEBUG=true
